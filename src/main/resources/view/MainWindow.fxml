<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0"
            prefWidth="400.0" style="-fx-background-color: E6E6FA;" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="dill.userinterface.gui.MainWindow">

    <TextField fx:id="userInput" layoutY="558.0" onAction="#handleUserInput" prefHeight="41.0" prefWidth="324.0"
               AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="95.0"
               style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-radius: 20;
               -fx-border-color: transparent; -fx-padding: 10 15 10 15; -fx-font-family: 'Verdana';
               -fx-font-size: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);"/>

    <Button fx:id="sendButton" layoutX="324.0" layoutY="558.0" mnemonicParsing="false" onAction="#handleUserInput"
            prefHeight="41.0" prefWidth="76.0" text="Send" AnchorPane.bottomAnchor="10.0" AnchorPane.rightAnchor="10.0"
            style="-fx-background-color: #6A5ACD; -fx-text-fill: #FFFFFF; -fx-background-radius: 20;
            -fx-padding: 10 20 10 20; -fx-font-family: 'Verdana'; -fx-font-weight: bold;
            -fx-font-size: 12px; -fx-cursor: hand;
            -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 4);">
    </Button>

    <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" hvalue="1.0" prefHeight="557.0"
                prefWidth="400.0" vvalue="1.0" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
                style="-fx-background-color: transparent; -fx-background: #E6E6FA;">
        <VBox fx:id="dialogContainer" prefWidth="388.0" style="-fx-background-color: E6E6FA;"/>
    </ScrollPane>

</AnchorPane>
